# ============================================
# BetAI - Environment Variables
# Copy this file to .env.local for local dev
# Add ALL of these to Vercel Environment Variables
# ============================================

# --- Database (Required) ---
# Use Neon, Supabase, or PlanetScale for serverless-friendly PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/betai?sslmode=require"

# --- Authentication (Required) ---
# Generate with: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# --- AI (Required for live predictions) ---
ANTHROPIC_API_KEY="sk-ant-..."

# --- Sports Data (Optional - enables real match data) ---
# Get free key at: rapidapi.com/api-sports/api/api-football
RAPIDAPI_KEY="your-rapidapi-key"

# --- Odds Data (Optional - enables real odds) ---
# Get free key at: the-odds-api.com
THE_ODDS_API_KEY="your-odds-api-key"

# --- Admin Setup (Required for first-time setup) ---
# Used to seed first admin user via POST /api/admin/seed
SETUP_SECRET="change-this-to-something-secret"
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="SecureAdminPassword123!"

# --- App URL (Required for Vercel) ---
NEXTAUTH_URL="https://your-app.vercel.app"
