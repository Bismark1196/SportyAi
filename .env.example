# ============================================
# BetAI — Environment Variables
# ============================================
# HOW TO USE:
#   Local dev:  copy to .env.local, fill in values
#   Vercel:     add each variable in Project → Settings → Environment Variables

# ─────────────────────────────────────────────
# DATABASE (Required)
# ─────────────────────────────────────────────
# Use Neon (free): https://neon.tech → New Project → copy "Connection string"
# It must start with:  postgresql://   or   postgres://
# WRONG ❌  postgresql:https://...apirest...
# RIGHT ✅  postgresql://user:pass@host.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://neondb_owner:npg_mr8Gh9LSvHfP@ep-still-hill-amg8qczx-pooler.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ─────────────────────────────────────────────
# AUTHENTICATION (Required)
# ─────────────────────────────────────────────
# Generate a secure secret: run this in terminal →  openssl rand -base64 32
# Paste the OUTPUT (a random string), NOT the command itself
JWT_SECRET="u1mNnuCSyohDbL9KDns0WfTpAiG4ec3KwTMaR9PZyQ4="

# ─────────────────────────────────────────────
# ANTHROPIC / CLAUDE AI (Required for live AI predictions)
# ─────────────────────────────────────────────
# 1. Go to: https://platform.claude.com
# 2. Click "API Keys" in the left sidebar
# 3. Click "Create Key" → copy the key (starts with sk-ant-api03-...)
# WRONG ❌  https://platform.claude.com/docs/...
# RIGHT ✅  sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY="sk-ant-api03-your-actual-key-here"

# ─────────────────────────────────────────────
# SPORTS DATA (Optional — app works without these using mock data)
# ─────────────────────────────────────────────
# Real fixture data: https://rapidapi.com/api-sports/api/api-football → Subscribe → copy API Key
RAPIDAPI_KEY="your-rapidapi-key"

# Live odds: https://the-odds-api.com → Sign up → copy API Key
THE_ODDS_API_KEY="9ef9c9ca28355686c9213f22c5bb4960"

# ─────────────────────────────────────────────
# FIRST-TIME ADMIN SETUP (Required once)
# ─────────────────────────────────────────────
# Choose any secret passphrase — used to call POST /api/admin/seed
SETUP_SECRET="BetAISetupSecret123!"
ADMIN_EMAIL="email@gmail.com"
ADMIN_PASSWORD="Password123!"

# ─────────────────────────────────────────────
# APP URL
# ─────────────────────────────────────────────
# After Vercel deploys, set this to your actual URL (no trailing slash)
NEXTAUTH_URL="https://your-app-name.vercel.app"
